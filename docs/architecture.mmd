    %% User → Ingress
    UA -->|"https://dev-indonesia.com"| DNS
    UB -->|"https://dev-indonesia.com"| DNS
    DNS --> CERTMGR
    CERTMGR -.->|"TLS cert"| NGINX
    DNS --> NGINX

    %% Ingress routing
    NGINX -->|"dev-indonesia.com"| PORTAL
    NGINX -->|"api-backend.dev-indonesia.com"| BACKEND
    NGINX -->|"apim.dev-indonesia.com"| APIM
    NGINX -->|"api.dev-indonesia.com"| APIM
    NGINX -->|"is.dev-indonesia.com"| IS
    NGINX -->|"grafana.dev-indonesia.com"| GRAFANA
    NGINX -->|"clickhouse.dev-indonesia.com"| CH
    NGINX -->|"kafka-ui.dev-indonesia.com"| KAFKAUI

    %% Portal → Backend
    PORTAL -->|"REST API"| BACKEND

    %% Backend → WSO2
    BACKEND -->|"OAuth2 token\nPublisher REST API"| APIM
    BACKEND -->|"SCIM2 / OIDC\nvalidasi user"| IS

    %% Backend → Data
    BACKEND -->|"SQL / HTTP"| CH
    BACKEND -->|"Produce / Consume"| KAFKA

    %% APIM → Mock endpoints
    APIM -->|"proxy request\n(api.dev-indonesia.com)"| BACKEND
    BACKEND --- M1 & M2 & M3 & M4 & M5 & M6 & M7 & M8 & M9

    %% Monitoring
    GRAFANA -->|"query"| CH
    KAFKAUI -->|"monitor"| KAFKA

    %% Auth flow
    IS -.->|"JWT token"| PORTAL
    IS -.->|"JWT token"| APIM

