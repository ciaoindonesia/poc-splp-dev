    %% User → Ingress
    UA -->|"https://pocsplp.com"| DNS
    UB -->|"https://pocsplp.com"| DNS
    DNS --> NGINX

    %% Ingress routing
    NGINX -->|"pocsplp.com"| PORTAL
    NGINX -->|"api-backend.pocsplp.com"| BACKEND
    NGINX -->|"apim.pocsplp.com"| APIM
    NGINX -->|"api.pocsplp.com"| APIM
    NGINX -->|"id.pocsplp.com"| IS
    NGINX -->|"grafana.pocsplp.com"| GRAFANA
    NGINX -->|"clickhouse.pocsplp.com"| CH

    %% Portal → Backend
    PORTAL -->|"REST API"| BACKEND

    %% Backend → WSO2
    BACKEND -->|"OAuth2 token\nPublisher REST API"| APIM
    BACKEND -->|"SCIM2 / OIDC\nvalidasi user"| IS

    %% Backend → Data
    BACKEND -->|"SQL / HTTP"| CH
    BACKEND -->|"Produce / Consume"| KAFKA

    %% APIM → Mock endpoints
    APIM -->|"proxy request\n(api.pocsplp.com)"| BACKEND
    BACKEND --- M1 & M2 & M3 & M4 & M5 & M6 & M7 & M8 & M9

    %% Monitoring
    GRAFANA -->|"query"| CH

    %% Auth flow
    IS -.->|"JWT token"| PORTAL
    IS -.->|"JWT token"| APIM

